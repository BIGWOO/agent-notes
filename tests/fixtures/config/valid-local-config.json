{
  "version": 1,
  "locale": "zh-TW",
  "vaultPath": "/tmp/agent-notes/vault",
  "projectMapPath": "/tmp/agent-notes/project-map.json",
  "privacy": {
    "defaultVisibility": "private",
    "recordAbsolutePathsInNotes": false,
    "copyRawTranscripts": false
